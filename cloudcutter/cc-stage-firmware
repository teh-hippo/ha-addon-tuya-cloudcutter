#!/usr/bin/env bash
# cc-stage-firmware — idempotently rebuild /opt/cloudcutter/custom-firmware/
# symlinks from operator-staged firmware in /share/cloudcutter-firmware/.
#
# Each regular file in /share/cloudcutter-firmware/ is symlinked into
# /opt/cloudcutter/custom-firmware/<same basename> so it's reachable via the
# path cloudcutter's OTA file handler hard-codes (/work/custom-firmware/ =
# /opt/cloudcutter/custom-firmware/). Stale symlinks pointing at
# /share/cloudcutter-firmware/ files that no longer exist are removed.
# Upstream-shipped kickstart binaries (regular files, not symlinks) are
# never touched.
#
# This script is re-runnable on demand:
#     bash /usr/local/bin/cc-stage-firmware
#
# History note:
#   v0.3.4 attempted a second pass that scanned ESPHome dashboard build
#   artefacts at /config/esphome/.esphome/build/<device>/.pioenvs/<env>/
#   image_*.<ext>. That design failed: the ESPHome HA add-on writes build
#   artefacts to its private /data directory (per esphome/core/__init__.py
#   data_dir() returning Path("/data") when is_ha_addon() is True), which
#   no other add-on can mount. The Pass 2 logic was removed in v0.3.5; for
#   the still-supported "compile in ESPHome dashboard, then flash via
#   cloudcutter" workflow, use the dashboard's Install → Manual Download
#   button to fetch the .ota.ug.bin to your local machine, then scp it
#   into /share/cloudcutter-firmware/ as <device>.ota.ug.bin. Or follow
#   the API approach tracked in the addon README as future work.

set -uo pipefail

CC_DIR=/opt/cloudcutter/custom-firmware
SHARE_DIR=/share/cloudcutter-firmware

mkdir -p "$CC_DIR" "$SHARE_DIR"

log() { echo "[cc-stage-firmware] $*"; }

# Step 1 — Clean stale symlinks pointing into our managed /share/ dir.
shopt -s nullglob
for link in "$CC_DIR"/*; do
  [[ -L "$link" ]] || continue
  target=$(readlink "$link")
  if [[ "$target" == "$SHARE_DIR"/* ]] && [[ ! -e "$target" ]]; then
    rm -f "$link"
    log "cleaned stale: $(basename "$link") -> $target"
  fi
done
shopt -u nullglob

# Step 2 — Symlink everything currently in /share/cloudcutter-firmware/.
shopt -s nullglob
for f in "$SHARE_DIR"/*; do
  [[ -f "$f" ]] || continue
  ln -sf "$f" "$CC_DIR/$(basename "$f")"
  log "staged: $(basename "$f") -> $f"
done
shopt -u nullglob

log "done. current symlinks:"
ls -la "$CC_DIR"/ 2>/dev/null | awk '$1 ~ /^l/ {print "  " $(NF-2), "->", $NF}'
